{
  "name": "bagel-evm",
  "version": "1.0.0",
  "description": "Bagel - Privacy-preserving payroll on Ethereum with Zama fhEVM",
  "keywords": ["ethereum", "privacy", "payroll", "fhe", "zama"],
  "author": "ConejoCapital",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "compile": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node --network hardhat --no-deploy",
    "deploy:local": "hardhat deploy --network localhost",
    "deploy:sepolia": "hardhat deploy --network sepolia",
    "typechain": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat typechain",
    "dev": "cd app && npm run dev"
  },
  "dependencies": {
    "@fhevm/solidity": "^0.11.1",
    "@openzeppelin/contracts": "^5.4.0",
    "@zama-fhe/oracle-solidity": "^0.1.0",
    "encrypted-types": "^0.0.4",
    "openzeppelin-confidential-contracts": "git+https://github.com/OpenZeppelin/openzeppelin-confidential-contracts.git#master"
  },
  "devDependencies": {
    "@fhevm/hardhat-plugin": "^0.4.2",
    "@fhevm/mock-utils": "^0.4.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.0",
    "@nomicfoundation/hardhat-verify": "^2.1.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.8",
    "@zama-fhe/relayer-sdk": "0.4.1",
    "chai": "^4.5.0",
    "cross-env": "^7.0.3",
    "ethers": "^6.16.0",
    "hardhat": "^2.27.0",
    "hardhat-deploy": "^0.11.45",
    "hardhat-gas-reporter": "^2.3.0",
    "solidity-coverage": "^0.8.16",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "elliptic@<6.6.0": ">=6.6.1"
  }
}
