# Bagel Privacy Payroll (EVM) - Environment Configuration
# Copy this file to .env.local and fill in your values

# =============================================================================
# EVM / fhEVM CONFIGURATION
# =============================================================================

# JSON-RPC URL (local Hardhat node or fhEVM testnet)
NEXT_PUBLIC_RPC_URL=http://localhost:8545

# Chain ID (default: Hardhat local = 31337)
NEXT_PUBLIC_CHAIN_ID=31337

# =============================================================================
# CONTRACT ADDRESSES (from deployment)
# =============================================================================

# BagelPayroll contract address
NEXT_PUBLIC_PAYROLL_ADDRESS=

# CERC20 (USDB) confidential token address
NEXT_PUBLIC_CERC20_ADDRESS=

# =============================================================================
# fhEVM ADDRESSES (auto-detected from Hardhat, set manually for testnet)
# =============================================================================

# ACL contract address
NEXT_PUBLIC_ACL_ADDRESS=

# KMS contract address
NEXT_PUBLIC_KMS_ADDRESS=

# Gateway URL for decrypt operations
NEXT_PUBLIC_GATEWAY_URL=http://localhost:7077

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Environment (development/production)
NODE_ENV=development

# Enable debug logging
NEXT_PUBLIC_DEBUG=false
